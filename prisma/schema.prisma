generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?   // For credential login
  role          String    @default("USER")
  department    String?   @default("Finance")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isApproved    Boolean   @default(true)
  isAllocator   Boolean   @default(false)
}

model Task {
  id                  Int       @id @default(autoincrement())
  taskName            String
  entityName          String
  taskType            String
  departmentName      String
  requestFrom         String
  ownerName           String
  reviewerName        String?   @default("Not Applicable")
  dueDate             DateTime?
  mailLink            String?
  ownerMailId         String?
  reviewerEmail       String?
  taskStatus          String    @default("Pending")
  reviewStatus        String    @default("Task Pending From Owner")
  completionDate      DateTime?
  reviewCompletionDate DateTime?
  ownerComments       String?
  reviewerComments    String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  editRequested       Boolean   @default(false)
  editRequestBy       String?   // "OWNER" or "REVIEWER"
  editRequestReason   String?
  deleteRequested     Boolean   @default(false)
  deleteRequestReason String?
  
  // Link to External Request
  linkedRequestId     Int?
  requestStatus       String?   @default("Pending")
  frequency           String?
}

model LearningOpportunity {
  id                  Int       @id @default(autoincrement())
  entity              String
  dateOfIdentification DateTime
  learningOpportunity String
  identifiedBy        String
  committedBy         String
  resolutionProvided  String
  modeOfCommunication String
  emailSub            String?
  comments            String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  editRequested       Boolean   @default(false)
  editApproved        Boolean   @default(false)
  editRequestReason   String?
  deleteRequested     Boolean   @default(false)
  deleteRequestReason String?
  createdByEmail      String?
}

model ExternalRequest {
  id                  Int       @id @default(autoincrement())
  requestFrom         String
  requesterEmail      String
  requestDate         DateTime  @default(now())
  natureOfRequest     String
  departmentName      String
  requestType         String
  status              String    @default("Under Process")
  assignedAllocatorEmail String?
  convertedTaskId     Int?
  rejectReason        String?
  frequency           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model SystemSettings {
  id                    String   @id @default("singleton")
  reminderFrequency     String   @default("DAILY")
  reminderTimes         String   @default("09:00,18:00")
  managerReportFrequency String   @default("DAILY")
  managerReportTimes     String   @default("10:00")
  loReportFrequency     String   @default("WEEKLY")
  loReportTimes         String   @default("10:00")
  lastReminderSentAt    DateTime?
  lastManagerReportSentAt DateTime?
  lastLoReportSentAt    DateTime?
  managerEmail          String   @default("pavanreddy@intellicar.in")
  loReportEmail         String   @default("pavanreddy@intellicar.in")

  // Master Data Lists (Comma separated)
  masterDepartments     String   @default("Finance,HR,IT,Operations,Sales,Marketing,Admin")
  masterEntities        String   @default("Intellicar-BLR,Intellicar-DEL,Intellicar-MUM,ITPL-Bangalore")
  masterTaskTypes       String   @default("Daily,Weekly,Monthly,Quarterly,Yearly,Statutory,Internal")
  masterFrequencies     String   @default("Daily,Weekly,Fortnightly,Monthly,Quarterly,Half Yearly,Yearly,Ad-hoc")
  masterCommunicationModes String  @default("Email,Verbal Discussion,Hangouts,Whatsapp-IC Group")
  masterRequestTypes    String   @default("Accounts Receivable,Accounts Payable,General & Administration,Payroll")
  masterRequestStatuses String   @default("Under Process,Pending for Review,Processed")

  // Matrices (JSON strings)
  moduleAccessMatrix    String   @default("{}")
  allocationMatrix      String   @default("{}")
}
